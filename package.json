{
  "name": "mentormatch",
  "version": "1.0.0",
  "description": "Premium mentorship marketplace with intelligent matching - SOLID architecture",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://mentormatch.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpha2420/MentorMatch.git"
  },
  "author": "Shikhar Singh",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "keywords": [
    "mentorship",
    "matching",
    "education",
    "typescript",
    "react",
    "solid-principles",
    "design-patterns"
  ]
}
